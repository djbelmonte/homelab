<div class="flex items-center justify-center min-h-screen bg-white px-4">
  <div class="bg-blue-50 shadow-lg rounded-2xl border border-blue-100 p-8 sm:p-10 max-w-md w-full">
    <h2 class="text-2xl font-bold text-blue-900 mb-6 text-center">Create your account</h2>

    <% if resource.errors.any? %>
      <div class="mb-4 bg-red-100 text-red-800 rounded p-4">
        <h3 class="font-semibold mb-2">Please fix the following:</h3>
        <ul class="list-disc list-inside text-sm">
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
      </div>

      <div>
        <%= f.submit "Sign up", class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-md transition" %>
      </div>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to "Already have an account? Log in", new_session_path(resource_name), class: "text-sm text-blue-600 hover:underline" %>
    </div>
  </div>
</div>
