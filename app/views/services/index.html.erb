<% content_for :title, "Services" %>

<%= search_form_for @q, url: services_path, method: :get, class: "mb-4" do |f| %>
  <div class="flex space-x-2">
    <%= f.search_field :name_or_price_cont, class: "w-full px-3 py-2 border rounded", placeholder: "Search name or price..." %>
    <%= f.submit "Search", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
  </div>
<% end %>

<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Services</h1>
  <%= link_to "New service", new_service_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 block font-medium text-white" %>
</div>

<%= render partial: "shared/table", locals: {
  columns: {
    "Name" => "name",
    "Price" => "price"
  },
  rows: @services.map { |service| { record: service, values: [service.name, number_to_currency(service.price)] } },
  actions: [
    { label: "Show", path: ->(s) { service_path(s) } },
    { label: "Edit", path: ->(s) { edit_service_path(s) } }
  ],
  pagy: @pagy,
  q: @q
} %>
