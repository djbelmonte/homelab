<% content_for :title, "Showing Service" %>

<%= render "shared/show_layout", {
  resource: @service,
  fields: {
    "Name" => @service.name,
    "Price" => number_to_currency(@service.price, unit: "₱"),
  },
  edit_path: edit_service_path(@service),
  delete_path: service_path(@service),
  back_path: services_path
} %>
