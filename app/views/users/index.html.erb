<%= search_form_for @q, url: users_path, method: :get, class: "mb-4" do |f| %>
  <div class="flex space-x-2">
    <%= f.search_field :name_or_email_cont, class: "w-full px-3 py-2 border rounded", placeholder: "Search name or email..." %>
    <%= f.submit "Search", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
  </div>
<% end %>

<%= render partial: "shared/table", locals: {
  columns: {
    "Name" => "name",
    "Email" => "email",
  },
  rows: @users.map { |user| { record: user, values: [user.name, user.email] } },
  actions: [
    { label: "Show", path: ->(u) { user_path(u) } },
    { label: "Edit", path: ->(u) { edit_user_path(u) } }
  ],
  pagy: @pagy,
  q: @q
} %>
