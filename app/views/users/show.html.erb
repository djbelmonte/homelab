<% content_for :title, "Showing User" %>

<%= render "shared/show_layout", {
  resource: @user,
  fields: {
    "Name" => @user.name,
    "Email" => @user.email,
    "Age" => @user.age,
    "Username" => @user.username,
    "Institution" => @user.institution.try(:name)
  },
  edit_path: edit_user_path(@user),
  delete_path: user_path(@user),
  back_path: users_path
} %>
