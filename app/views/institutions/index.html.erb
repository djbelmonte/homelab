<% content_for :title, "Institutions" %>

<%= search_form_for @q, url: institutions_path, method: :get, class: "mb-4" do |f| %>
  <div class="flex space-x-2">
    <%= f.search_field :name_or_address_or_contact_number_cont, class: "w-full px-3 py-2 border rounded", placeholder: "Search institution..." %>
    <%= f.submit "Search", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
  </div>
<% end %>

<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Institutions</h1>
  <%= link_to "New institution", new_institution_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 block font-medium text-white" %>
</div>

<%= render partial: "shared/table", locals: {
  columns: {
    "Name" => "name",
    "Address" => "address",
    "Contact Number" => "contact_number"
  },
  rows: @institutions.map { |institution|
    {
      record: institution,
      values: [
        institution.name,
        institution.address,
        institution.contact_number
      ]
    }
  },
  actions: [
    { label: "Show", path: ->(i) { institution_path(i) } },
    { label: "Edit", path: ->(i) { edit_institution_path(i) } }
  ],
  pagy: @pagy,
  q: @q
} %>
