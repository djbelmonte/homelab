<% content_for :title, "Institution" %>

<%= render "shared/show_layout", {
  resource: @institution,
  fields: {
    "Name" => @institution.name,
    "Address" => @institution.address,
    "Contact Number" => @institution.contact_number,
    "Created At" => l(@institution.created_at, format: :long)
  },
  edit_path: edit_institution_path(@institution),
  delete_path: institution_path(@institution),
  back_path: institutions_path
} %>
