<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-4 lg:gap-8">

    <!-- Main Details Section (75% width on lg screens) -->
    <div class="lg:col-span-3 bg-white shadow rounded-lg p-6 mb-6 lg:mb-0">
      <h1 class="text-2xl font-semibold text-gray-800 mb-4">
        <%= resource.try(:title) || "#{resource.class.name} Details" %>
      </h1>

      <dl class="divide-y divide-gray-200 space-y-4">
        <% fields.each do |label, value| %>
          <div class="pt-2">
            <dt class="text-sm font-medium text-gray-500"><%= label %></dt>
            <dd class="mt-1 text-gray-800"><%= value %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Actions Panel (25% width on lg screens) -->
    <div class="lg:col-span-1 bg-white shadow rounded-lg p-6 h-fit">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Actions</h2>

      <% if edit_path %>
        <%= link_to 'Edit', edit_path, class: "block w-full text-center bg-blue-100 hover:bg-blue-200 text-gray-800 font-semibold py-2 px-4 rounded mb-5" %>
      <% end %>

      <% if delete_path %>
        <%= link_to 'Delete', delete_path, method: :delete, data: { confirm: "Are you sure?" }, class: "block w-full text-center bg-blue-100 hover:bg-blue-200 text-gray-800 font-semibold py-2 px-4 rounded mb-5" %>
      <% end %>

      <% if back_path %>
        <%= link_to 'Back', back_path, class: "block w-full text-center bg-blue-100 hover:bg-blue-200 text-gray-800 font-semibold py-2 px-4 rounded" %>
      <% end %>
    </div>

  </div>
</div>
