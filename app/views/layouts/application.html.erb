<!DOCTYPE html>
<html>
  <head>
    <title>Homelab</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", type: "module", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-50 text-gray-800 min-h-screen">

    <% if user_signed_in? %>
      <div class="flex min-h-screen">
         <!-- Sidebar (only for logged-in users) -->
        <% if user_signed_in? %>
          <aside class="hidden lg:block lg:w-[15%] min-h-screen bg-blue-50 border-r border-blue-100 shadow-md rounded-r-2xl p-4">
            <!-- Centered Logo -->
            <div class="mb-6 flex justify-center">
              <%= link_to root_path do %>
                <%= image_tag "logo.png", alt: "Logo", class: "h-10 w-auto" %>
              <% end %>
            </div>
            <nav class="space-y-2">
              <%= link_to dashboard_path, class: "block px-4 py-2 rounded-lg text-blue-900 hover:bg-blue-100 font-medium" do %>
                📊 Dashboard
              <% end %>
              <%= link_to institutions_path, class: "block px-4 py-2 rounded-lg text-blue-900 hover:bg-blue-100 font-medium" do %>
                🏥 Institutions
              <% end %>
              <%= link_to users_path, class: "block px-4 py-2 rounded-lg text-blue-900 hover:bg-blue-100 font-medium" do %>
                👥 Users
              <% end %>
              <%= link_to services_path, class: "block px-4 py-2 rounded-lg text-blue-900 hover:bg-blue-100 font-medium" do %>
                🧪 Services
              <% end %>
              <%= link_to user_path(current_user), class: "block px-4 py-2 rounded-lg text-blue-900 hover:bg-blue-100 font-medium" do %>
                🙍‍♂️ My Profile
              <% end %>
            </nav>
          </aside>
        <% end %>

        <!-- Main area -->
        <div class="flex-1 flex flex-col">
          <!-- Top bar -->
          <header class="bg-white shadow px-6 py-4 flex justify-between items-center">
            <h1 class="text-xl font-semibold text-gray-700"></h1>

            <div class="relative inline-block text-left">
              <button id="user-menu-button" type="button" class="inline-flex items-center text-gray-700 hover:text-blue-700 focus:outline-none">
                <span class="mr-2"><%= current_user.email %></span>
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              <!-- Dropdown -->
              <div id="user-dropdown" class="hidden absolute right-0 mt-2 w-48 bg-white border border-gray-200 rounded shadow-md z-50">
                <%= link_to "My Profile", user_path(current_user), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "Log out", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "block px-4 py-2 text-sm text-red-600 hover:bg-gray-100" %>
              </div>
            </div>
          </header>

          <!-- Flash -->
          <% flash.each do |type, message| %>
            <div class="bg-<%= type == 'notice' ? 'green' : 'red' %>-100 text-<%= type == 'notice' ? 'green' : 'red' %>-800 p-4 text-sm text-center">
              <%= message %>
            </div>
          <% end %>

          <!-- Page content -->
          <main class="flex-1 p-6">
            <div class="max-w-7xl mx-auto">
              <%= yield %>
            </div>

            <% if content_for?(:sidebar) %>
              <div class="mt-8">
                <%= yield :sidebar %>
              </div>
            <% end %>
          </main>
        </div>
      </div>

      <!-- Toggle dropdown script -->
      <script>
        document.addEventListener('turbo:load', () => {
          const button = document.getElementById('user-menu-button');
          const dropdown = document.getElementById('user-dropdown');

          if (button && dropdown) {
            button.addEventListener('click', (e) => {
              e.preventDefault();
              dropdown.classList.toggle('hidden');
            });

            document.addEventListener('click', (e) => {
              if (!button.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add('hidden');
              }
            });
          }
        });
      </script>


    <% else %>
      <!-- Guest layout -->
      <header class="bg-blue-100 shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <%= link_to root_path do %>
              <%= image_tag "logo.png", alt: "Logo", class: "h-10 w-auto" %>
            <% end %>

            <div class="flex items-center space-x-4">
              <%= link_to "Log in", new_user_session_path, class: "text-blue-800 hover:underline" %>
              <%= link_to "Sign up", new_user_registration_path, class: "text-blue-800 hover:underline" %>
            </div>
          </div>
        </div>
      </header>

      <main class="px-4 sm:px-6 lg:px-8 py-6">
        <% flash.each do |type, message| %>
          <div class="mb-4 bg-<%= type == 'notice' ? 'green' : 'red' %>-100 text-<%= type == 'notice' ? 'green' : 'red' %>-800 p-4 text-sm rounded text-center">
            <%= message %>
          </div>
        <% end %>

        <div class="max-w-3xl mx-auto">
          <%= yield %>
        </div>
      </main>
    <% end %>

  </body>
</html>
