<h1 class="text-2xl font-bold mb-6">My Bookings</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @bookings.each do |booking| %>
    <%= link_to booking_path(booking), class: "w-1/3 p-4 block" do %>
      <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
        <h2 class="text-xl font-semibold mb-2"><%= booking.title %></h2>
        <p class="text-gray-600 mb-1"><strong>Status:</strong> <%= booking.status.capitalize %></p>
        <p class="text-gray-600 mb-1"><strong>Time:</strong> <%= booking.time.strftime("%B %d, %Y %I:%M %p") %></p>
        <p class="text-gray-600 mb-1"><strong>Address:</strong> <%= booking.address %></p>
        <p class="text-gray-500 text-sm mt-3"><%= time_ago_in_words(booking.created_at) %> ago</p>
      </div>
    <% end %>
  <% end %>
</div>