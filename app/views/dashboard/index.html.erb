<h1 class="text-2xl font-bold mb-6">Orders</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @bookings.each do |booking| %>
    <%= link_to booking_path(booking), class: "relative white block p-6 border border-black-100 rounded-lg max-w-sm mx-auto mt-24" do %>
      <span class="absolute inset-x-0 bottom-0 h-2 bg-orange-600"></span>
      <div class="my-4">
        <p class="text-<%= booking.booking_status_color %>-600 mb-1"><strong>Status:</strong> <%= booking.status.capitalize %></p>
        <p class="text-gray-600 mb-1"><strong>Time:</strong> <%= booking.time.strftime("%B %d, %Y %I:%M %p") %></p>
        <p class="text-gray-600 mb-1"><strong>Address:</strong> <%= booking.address %></p>
        <p class="text-gray-600 mb-1"><strong>Name:</strong> <%= booking.user.name %></p>
        <p class="text-gray-600 mb-1"><strong>Order:</strong> <%= booking.orders.map{|order| order.service.name}.join(", ") %></p>
        <p class="text-gray-500 text-sm mt-3"><%= time_ago_in_words(booking.created_at) %> ago</p>
      </div>
    <% end %>
  <% end %>
</div>