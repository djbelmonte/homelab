<div id="<%= dom_id booking %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Services:</strong>
    <%= booking.orders.map{|order| order.service.name}.join(", ") %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= booking.status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Time:</strong>
    <%= booking.time %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Address:</strong>
    <%= booking.address %>
  </div>
  <div>
    <strong class="block font-medium mb-1">User:</strong>
    <%= booking.user.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Notes:</strong>
    <%= booking.notes %>
  </div>
</div>
