<%= render "shared/show_layout", 
      resource: @booking, 
      fields: [
        ["Notes", @booking.notes],
        ["Status", @booking.status],
        ["Time", l(@booking.time, format: :long)],
        ["Address", @booking.address],
        ["Services", @booking.services.map { |s| "#{s.name} (#{number_to_currency(s.price)})" }.join(", ").html_safe]
      ],
      back_path: bookings_path,
      edit_path: edit_booking_path(@booking),
      delete_path: booking_path(@booking) %>