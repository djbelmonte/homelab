<%= styled_form_with(model: @booking, local: true) do |form| %>
  <div class="my-5">
    <%= form.label :service_ids, "Select Services", class: "block text-sm font-medium text-gray-700 mb-2" %>

    <div class="space-y-3">
      <% Service.all.each do |service| %>
        <div class="flex items-center space-x-2">
          <%= check_box_tag "booking[service_ids][]", service.id, @booking.service_ids.include?(service.id), id: "service_#{service.id}", class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
          <%= label_tag "service_#{service.id}", "#{service.name} (#{number_to_currency(service.price, unit: "₱")})", class: "text-gray-700" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="my-5">
    <%= form.label :time %>
    <%= form.datetime_field :time, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking.errors[:time].none?, "border-red-400 focus:outline-red-600": booking.errors[:time].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :address %>
    <%= form.text_field :address, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking.errors[:address].none?, "border-red-400 focus:outline-red-600": booking.errors[:address].any?}] %>
  </div>

   <div class="my-5">
    <%= form.label :notes %>
    <%= form.text_area :notes, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking.errors[:notes].none?, "border-red-400 focus:outline-red-600": booking.errors[:notes].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>

<% end %>