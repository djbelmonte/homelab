<%= styled_form_with(model: @booking, local: true) do |form| %>
  <div class="mb-4">
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

  <div class="mb-4">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 3 %>
  </div>

  <div class="mb-4">
    <%= form.label :time %>
    <%= form.datetime_field :time %>
  </div>

  <div class="mb-4">
    <%= form.label :address %>
    <%= form.text_field :address %>
  </div>

  <div class="mb-4">
    <%= form.label :user_id %>
    <%= form.text_field :user_id %>
  </div>

  <div class="mb-4">
    <%= form.submit "Save Booking" %>
  </end>
<% end %>